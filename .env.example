# Trusted-checkout settings used by the explicit seed helper. The main CLI does
# not auto-load a target checkout's .env. Never commit a real token.
DATAHUB_GMS_URL=http://127.0.0.1:8080
DATAHUB_GMS_TOKEN_FILE=.lineageguard/datahub-token
DATAHUB_FRONTEND_URL=http://127.0.0.1:9002
# Optional for non-interactive first-run token creation. Keep the password out
# of committed files; an interactive run prompts without echoing it.
# DATAHUB_LOCAL_USERNAME=datahub
# DATAHUB_LOCAL_PASSWORD=
